{
  "id": "member-vector-push-back",
  "title": "vector::push_back",
  "category": "STL Member Functions",
  "aliases": ["push_back", "push", "add", "vec push", "pushback"],
  "inputs": [
    {
      "id": "vectorName",
      "label": "Vector Variable Name",
      "type": "string",
      "default": "v",
      "validation": {
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "message": "Must be a valid C++ identifier"
      }
    },
    {
      "id": "value",
      "label": "Value to push",
      "type": "string",
      "default": "x"
    }
  ],
  "template": "{{vectorName}}.push_back({{value}});"
}
