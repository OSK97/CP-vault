{
  "id": "algorithm-replace",
  "title": "replace",
  "category": "STL Algorithms (Modification)",
  "aliases": [
    "replace",
    "swap values in range"
  ],
  "inputs": [
    {
      "id": "container",
      "label": "Container Variable",
      "type": "string",
      "default": "v",
      "validation": {
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "message": "Must be a valid C++ identifier"
      }
    },
    {
      "id": "oldVal",
      "label": "Old Value to Replace",
      "type": "string",
      "default": "old_x"
    },
    {
      "id": "newVal",
      "label": "New Value",
      "type": "string",
      "default": "new_x"
    }
  ],
  "template": "replace({{container}}.begin(), {{container}}.end(), {{oldVal}}, {{newVal}});"
}