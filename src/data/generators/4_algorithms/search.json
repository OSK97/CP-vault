{
  "id": "algorithm-search",
  "title": "search",
  "category": "STL Algorithms (Searching)",
  "aliases": [
    "search",
    "find subsequence",
    "match subrange"
  ],
  "inputs": [
    {
      "id": "c1",
      "label": "Source Container",
      "type": "string",
      "default": "v",
      "validation": {
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "message": "Must be a valid C++ identifier"
      }
    },
    {
      "id": "c2",
      "label": "Subsequence Container",
      "type": "string",
      "default": "s",
      "validation": {
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "message": "Must be a valid C++ identifier"
      }
    }
  ],
  "template": "auto it = search({{c1}}.begin(), {{c1}}.end(), {{c2}}.begin(), {{c2}}.end());"
}