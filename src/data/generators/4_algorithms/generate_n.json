{
  "id": "algorithm-generate-n",
  "title": "generate_n",
  "category": "STL Algorithms (Modification)",
  "aliases": [
    "generate_n",
    "fill generated values n elements"
  ],
  "inputs": [
    {
      "id": "container",
      "label": "Container Variable",
      "type": "string",
      "default": "v",
      "validation": {
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "message": "Must be a valid C++ identifier"
      }
    },
    {
      "id": "count",
      "label": "Element Count",
      "type": "string",
      "default": "n"
    },
    {
      "id": "generator",
      "label": "Generator Function / Lambda",
      "type": "string",
      "default": "rand"
    }
  ],
  "template": "generate_n({{container}}.begin(), {{count}}, {{generator}});"
}