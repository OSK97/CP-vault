{
  "id": "algorithm-move",
  "title": "move",
  "category": "STL Algorithms (Modification)",
  "aliases": [
    "move",
    "transfer range"
  ],
  "inputs": [
    {
      "id": "source",
      "label": "Source Container",
      "type": "string",
      "default": "v",
      "validation": {
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "message": "Must be a valid C++ identifier"
      }
    },
    {
      "id": "dest",
      "label": "Destination Container/Iterator",
      "type": "string",
      "default": "res",
      "validation": {
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "message": "Must be a valid C++ identifier"
      }
    }
  ],
  "template": "move({{source}}.begin(), {{source}}.end(), {{dest}}.begin());"
}