{
  "id": "algorithm-fill-n",
  "title": "fill_n",
  "category": "STL Algorithms (Modification)",
  "aliases": [
    "fill_n",
    "initialize n elements"
  ],
  "inputs": [
    {
      "id": "container",
      "label": "Container Variable",
      "type": "string",
      "default": "v",
      "validation": {
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "message": "Must be a valid C++ identifier"
      }
    },
    {
      "id": "count",
      "label": "Element Count",
      "type": "string",
      "default": "n"
    },
    {
      "id": "value",
      "label": "Fill Value",
      "type": "string",
      "default": "0"
    }
  ],
  "template": "fill_n({{container}}.begin(), {{count}}, {{value}});"
}