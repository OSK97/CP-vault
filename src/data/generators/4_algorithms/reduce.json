{
  "id": "algorithm-reduce",
  "title": "reduce",
  "category": "STL Algorithms (Numeric)",
  "aliases": [
    "reduce",
    "sum parallel",
    "sum"
  ],
  "inputs": [
    {
      "id": "container",
      "label": "Container Variable",
      "type": "string",
      "default": "v",
      "validation": {
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "message": "Must be a valid C++ identifier"
      }
    },
    {
      "id": "init",
      "label": "Initial Value",
      "type": "string",
      "default": "0"
    }
  ],
  "template": "auto sum = reduce({{container}}.begin(), {{container}}.end(), {{init}});"
}