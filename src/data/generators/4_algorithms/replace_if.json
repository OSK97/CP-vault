{
  "id": "algorithm-replace-if",
  "title": "replace_if",
  "category": "STL Algorithms (Modification)",
  "aliases": [
    "replace_if",
    "replace matching values"
  ],
  "inputs": [
    {
      "id": "container",
      "label": "Container Variable",
      "type": "string",
      "default": "v",
      "validation": {
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "message": "Must be a valid C++ identifier"
      }
    },
    {
      "id": "predicate",
      "label": "Predicate Function / Lambda",
      "type": "string",
      "default": "[](int x) { return x < 0; }"
    },
    {
      "id": "newVal",
      "label": "New Value",
      "type": "string",
      "default": "0"
    }
  ],
  "template": "replace_if({{container}}.begin(), {{container}}.end(), {{predicate}}, {{newVal}});"
}