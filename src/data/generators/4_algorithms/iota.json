{
  "id": "algorithm-iota",
  "title": "iota",
  "category": "STL Algorithms (Numeric)",
  "aliases": [
    "iota",
    "fill sequential",
    "range fill"
  ],
  "inputs": [
    {
      "id": "container",
      "label": "Container Variable",
      "type": "string",
      "default": "v",
      "validation": {
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "message": "Must be a valid C++ identifier"
      }
    },
    {
      "id": "start",
      "label": "Start Value",
      "type": "string",
      "default": "0"
    }
  ],
  "template": "iota({{container}}.begin(), {{container}}.end(), {{start}});"
}