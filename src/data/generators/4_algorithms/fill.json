{
  "id": "algorithm-fill",
  "title": "fill",
  "category": "STL Algorithms (Modification)",
  "aliases": [
    "fill",
    "initialize all"
  ],
  "inputs": [
    {
      "id": "container",
      "label": "Container Variable",
      "type": "string",
      "default": "v",
      "validation": {
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "message": "Must be a valid C++ identifier"
      }
    },
    {
      "id": "value",
      "label": "Fill Value",
      "type": "string",
      "default": "0"
    }
  ],
  "template": "fill({{container}}.begin(), {{container}}.end(), {{value}});"
}