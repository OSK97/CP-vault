{
  "id": "algorithm-search-n",
  "title": "search_n",
  "category": "STL Algorithms (Searching)",
  "aliases": [
    "search_n",
    "find consecutive",
    "consecutive count"
  ],
  "inputs": [
    {
      "id": "container",
      "label": "Container Variable",
      "type": "string",
      "default": "v",
      "validation": {
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "message": "Must be a valid C++ identifier"
      }
    },
    {
      "id": "count",
      "label": "Consecutive Count",
      "type": "string",
      "default": "n"
    },
    {
      "id": "value",
      "label": "Target Value",
      "type": "string",
      "default": "x"
    }
  ],
  "template": "auto it = search_n({{container}}.begin(), {{container}}.end(), {{count}}, {{value}});"
}