{
  "id": "algorithm-copy-if",
  "title": "copy_if",
  "category": "STL Algorithms (Modification)",
  "aliases": [
    "copy_if",
    "copy matching"
  ],
  "inputs": [
    {
      "id": "source",
      "label": "Source Container",
      "type": "string",
      "default": "v",
      "validation": {
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "message": "Must be a valid C++ identifier"
      }
    },
    {
      "id": "dest",
      "label": "Destination Container/Iterator",
      "type": "string",
      "default": "res",
      "validation": {
        "pattern": "^[a-zA-Z_][a-zA-Z0-9_]*$",
        "message": "Must be a valid C++ identifier"
      }
    },
    {
      "id": "predicate",
      "label": "Predicate Function / Lambda",
      "type": "string",
      "default": "[](int x) { return x > 0; }"
    }
  ],
  "template": "copy_if({{source}}.begin(), {{source}}.end(), {{dest}}.begin(), {{predicate}});"
}